<footer class="footer-root">
  <div class="section-container">
    <div class="footer-inner">
      <!-- Social icons (left on desktop, top-center on mobile) -->
      <div class="footer-social">
        <a href="https://linkedin.com/in/jonaruiz" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href="https://dribbble.com/Jonathanruiz" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Dribbble profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M19.13 5.09C15.22 9.14 10 10.44 2.25 10.94"/>
            <path d="M21.75 12.84c-6.62-1.41-12.14 1-16.38 6.32"/>
            <path d="M8.56 2.75c4.37 6 6 9.42 8 17.72"/>
          </svg>
        </a>
        <a href="https://github.com/jonathanruizg" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub profile">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        </a>
        <a href="mailto:jonathanruizg@me.com" class="social-link" aria-label="Send email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
      </div>

      <!-- Center: copyright + built with -->
      <div class="footer-mid">
        <p class="footer-copy">&copy; 2026 Jonathan Ruiz</p>
        <p class="footer-center">Designed &amp; built with Astro, Tailwind &amp; Claude Code</p>
      </div>

      <!-- Nav links -->
      <div class="footer-links">
        <a href="/styleguide">Styleguide</a>
        <span class="footer-sep">·</span>
        <a href="/#community">Community</a>
        <span class="footer-sep">·</span>
        <a href="/#vibe-coding">Vibe Coding</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    border-top: 1px solid var(--border);
    padding-bottom: 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    gap: 1rem;
  }

  /* Social icons */
  .footer-social {
    display: none;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    border-radius: 8px;
    padding: 0.6rem;
    color: var(--text-3);
    transition: color 0.15s;
    text-decoration: none;
  }
  .social-link:hover { color: var(--text); }

  /* Center block */
  .footer-mid {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    flex: 1;
    text-align: left;
  }

  .footer-copy,
  .footer-center {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-3);
    margin: 0;
    white-space: nowrap;
  }

  /* Nav links */
  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--text); }
  .footer-sep {
    font-size: 0.68rem;
    color: var(--text-3);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .footer-social {
      display: flex;
    }
    .footer-root {
      padding-bottom: 5rem;
    }
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
    }
    .footer-copy,
    .footer-center {
      white-space: normal;
    }
    .footer-mid {
      flex: unset;
      align-items: center;
      text-align: center;
    }
  }
</style>
