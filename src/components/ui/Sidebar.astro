---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

const isWork       = currentPath.startsWith('/work');
const isAbout      = currentPath.startsWith('/about');
const isLeadership = currentPath.startsWith('/leadership');

const navLinks = [
  { label: 'Work',       href: '/work' },
  { label: 'About',      href: '/about' },
  { label: 'Leadership', href: '/leadership' },
];

function isActive(href: string) {
  if (href === '/work')       return isWork;
  if (href === '/about')      return isAbout;
  if (href === '/leadership') return isLeadership;
  return false;
}

const socialLinks = [
  {
    label: 'LinkedIn profile',
    href: 'https://linkedin.com/in/jonaruiz',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    label: 'Dribbble profile',
    href: 'https://dribbble.com/Jonathanruiz',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M19.13 5.09C15.22 9.14 10 10.44 2.25 10.94"/><path d="M21.75 12.84c-6.62-1.41-12.14 1-16.38 6.32"/><path d="M8.56 2.75c4.37 6 6 9.42 8 17.72"/>`,
  },
  {
    label: 'GitHub profile',
    href: 'https://github.com/jonathanruizg',
    icon: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  },
  {
    label: 'Send email',
    href: 'mailto:jonathanruizg@me.com',
    icon: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  },
];
---

<!-- ── Desktop sidebar ── -->
<aside class="sidebar">

  <!-- Logo -->
  <div class="sidebar-section">
    <a href="/" class="logo-link">
      <img src="/JRU-black.svg" alt="Jonathan Ruiz logo mark" class="logo-img logo-light" />
      <img src="/JRU-white.svg" alt="Jonathan Ruiz logo mark" class="logo-img logo-dark" />
    </a>
  </div>

  <div class="sidebar-divider"></div>

  <!-- Nav -->
  <nav class="sidebar-section">
    <ul>
      {navLinks.map(link => (
        <li>
          <a href={link.href} class={isActive(link.href) ? 'active' : ''}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Spacer -->
  <div style="flex: 1;"></div>

  <div class="sidebar-divider"></div>

  <!-- Social icons -->
  <div class="sidebar-section sidebar-bottom">
    <div class="sidebar-social">
      {socialLinks.map(s => (
        <a href={s.href} target={s.href.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer" aria-label={s.label}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
        </a>
      ))}
    </div>
  </div>

</aside>

<!-- ── Mobile top bar ── -->
<div class="mobile-bar">
  <a href="/" class="logo-link">
    <img src="/JRU-black.svg" alt="JR" class="logo-img logo-light" />
    <img src="/JRU-white.svg" alt="JR" class="logo-img logo-dark" />
  </a>

  <div class="mobile-bar-right">
    <nav class="mobile-nav">
      {navLinks.map(link => (
        <a href={link.href} class={isActive(link.href) ? 'active' : ''}>{link.label}</a>
      ))}
    </nav>
    <button id="mob-theme-btn" class="mob-theme-btn" aria-label="Toggle theme">
      <svg id="mob-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      <svg id="mob-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="display:none"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
    </button>
  </div>
</div>

<style>
  /* ── Sidebar (desktop) ── */
  .sidebar {
    position: fixed;
    left: 0; top: 0;
    width: 220px;
    height: 100vh;
    display: none;
    flex-direction: column;
    padding: 1.5rem 1rem;
    background-color: var(--bg);
    border-right: 1px solid var(--border);
    z-index: 40;
  }
  @media (min-width: 768px) {
    .sidebar { display: flex; }
  }

  .sidebar-section { padding: 0 0.1rem; }
  .sidebar-divider {
    height: 1px;
    background-color: var(--border);
    margin: 1rem 0;
  }

  /* ── Nav ── */
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  nav a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-3);
    text-decoration: none;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    display: block;
  }
  nav a:hover {
    color: var(--text);
    background: var(--bg-2);
  }
  nav a.active {
    color: var(--accent);
    font-weight: 500;
  }

  /* ── Social + Theme ── */
  .sidebar-bottom {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sidebar-social {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }
  .sidebar-social a {
    color: var(--text-3);
    display: flex;
    align-items: center;
    padding: 0.3rem;
    border-radius: 4px;
    transition: color 0.15s;
    text-decoration: none;
  }
  .sidebar-social a:hover { color: var(--text); }

  /* ── Logo ── */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
    padding: 0.25rem 0;
    transition: opacity 0.2s;
  }
  .logo-link:hover { opacity: 0.75; }

  .logo-img { width: 32px; height: auto; flex-shrink: 0; margin-top: 2px; }
  .logo-name {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    display: block;
  }
  .logo-title {
    font-size: 0.65rem;
    color: var(--text-3);
    font-weight: 400;
    display: block;
    margin-top: 0.1rem;
  }

  /* Theme-aware logo swap */
  .logo-dark { display: none; }
  .logo-light { display: block; }
  :global([data-theme="dark"]) .logo-dark  { display: block; }
  :global([data-theme="dark"]) .logo-light { display: none;  }

  /* ── Mobile top bar ── */
  .mobile-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    height: 52px;
    position: fixed;
    top: 0; left: 0; right: 0;
    background-color: var(--bg);
    border-bottom: 1px solid var(--border);
    z-index: 50;
  }
  @media (min-width: 768px) {
    .mobile-bar { display: none; }
  }

  .mobile-bar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-nav {
    display: flex;
    gap: 0.15rem;
  }
  .mobile-nav a {
    font-size: 0.8rem;
    color: var(--text-3);
    text-decoration: none;
    padding: 0.25rem 0.45rem;
    border-radius: 5px;
    transition: color 0.15s, background 0.15s;
  }
  .mobile-nav a:hover { color: var(--text); background: var(--bg-2); }
  .mobile-nav a.active { color: var(--accent); font-weight: 500; }

  .mob-theme-btn {
    background: none;
    border: none;
    color: var(--text-3);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .mob-theme-btn:hover { color: var(--text); }
</style>

<script>
  const mobBtn = document.getElementById('mob-theme-btn');
  const mobMoon = document.getElementById('mob-moon');
  const mobSun = document.getElementById('mob-sun');

  function syncMobIcons() {
    const dark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (mobMoon) (mobMoon as HTMLElement).style.display = dark ? 'none' : 'block';
    if (mobSun)  (mobSun as HTMLElement).style.display  = dark ? 'block' : 'none';
  }

  syncMobIcons();

  mobBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const next = isDark ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    syncMobIcons();
    // Also sync the desktop toggle icons if present
    const deskMoon = document.getElementById('icon-moon');
    const deskSun  = document.getElementById('icon-sun');
    if (deskMoon) (deskMoon as HTMLElement).style.display = next === 'dark' ? 'none' : 'block';
    if (deskSun)  (deskSun as HTMLElement).style.display  = next === 'dark' ? 'block' : 'none';
  });
</script>

