---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import Footer from '../components/ui/Footer.astro';
import ChatWidget from '../components/chat/ChatWidget.tsx';

const principles = [
{
number: '01',
title: 'Build by doing',
body: "I learn by building and solving real problems. Writing code, debugging systems, and working with real-world scenarios help me grow faster than theory alone.",
icon: "<path d="M9 9l5 12 1.8-5.2L21 14Z"/><path d="M7.2 2.2L8 5.1"/><path d="m5.1 8-2.9-.8"/><path d="M14 4.1 12 6"/><path d="m6 12-1.9 2"/>",
},
{
number: '02',
title: 'Solve real problems',
body: "My focus is on building solutions that actually work in production. I aim to remove bottlenecks, improve performance, and create systems that serve real users effectively.",
icon: "<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="m12 5-2 2.5-2-1-2 3"/>",
},
{
number: '03',
title: 'Think in systems',
body: "I focus on how different parts of a system connect and work together. Good backend development is not just about features, but about building reliable and scalable architectures.",
icon: "<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>",
},
{
number: '04',
title: 'Keep learning',
body: "Technology evolves quickly, so I stay curious and open to learning. I improve by exploring new tools, learning from feedback, and continuously refining my approach.",
icon: "<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>",
},
{
number: '05',
title: 'Consistency matters',
body: "Reliable systems come from consistent effort. I focus on writing clean code, maintaining quality, and building solutions that are stable and long-lasting.",
icon: "<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>",
},
];
---

<Layout title="Principles | Mirazul Haq Srabon" description=" building scalable backend systems, writing clean code, and solving real-world problems through reliable software.">
  <Sidebar currentPath={Astro.url.pathname} />

  <div class="content-area pt-14 md:pt-0">
    <main id="main-content">
      <section class="section-padding">
        <div class="section-container">

          <!-- Back home -->
          <a href="/" class="back-home">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back home
          </a>

          <!-- Header -->
          <div class="mb-16">
            <p class="label mb-3">Leadership</p>
            <h1 class="section-title mb-5" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.1; letter-spacing: -0.02em;">
              How I think about<br />leading people.
            </h1>
            <p class="body-text max-w-lg">
              Leadership isn't a title. It's a practice. These are the principles that guide how I show up for my team, my peers and the people I mentor.
            </p>
          </div>

          <!-- Principles list -->
          <div class="divide-y" style="border-color: var(--border);">
            {principles.map((p) => (
              <div class="py-10 grid md:grid-cols-[80px_1fr] gap-6 items-start">
                <!-- Number + icon -->
                <div class="flex md:flex-col items-center md:items-start gap-3">
                  <span
                    class="text-sm tabular-nums"
                    style="font-family: 'DM Mono', monospace; color: var(--text-3);"
                  >
                    {p.number}
                  </span>
                  <div
                    class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="background-color: var(--accent-light);"
                  >
                    <svg
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      style="color: var(--accent);"
                      set:html={p.icon}
                    />
                  </div>
                </div>

                <!-- Content -->
                <div>
                  <h2 class="text-xl font-semibold mb-3" style="color: var(--text); letter-spacing: -0.01em;">
                    {p.title}
                  </h2>
                  <p class="body-text max-w-prose leading-relaxed">
                    {p.body}
                  </p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </section>
    </main>
    <Footer />
  </div>

  <ChatWidget client:only="react" />
</Layout>
